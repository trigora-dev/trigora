{
  "name": "@trigora/sdk",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/trigora-dev/trigora"
  },
  "homepage": "https://trigora.dev/",
  "bugs": {
    "url": "https://github.com/trigora-dev/trigora/issues"
  },
  "keywords": [
    "automation",
    "workflow",
    "event-driven",
    "developer-tools",
    "typescript",
    "cli",
    "triggers",
    "cron",
    "webhooks"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:types",
    "build:js": "tsup",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@trigora/contracts": "0.2.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
