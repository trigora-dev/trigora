{
    "compilerOptions": {
        "paths": {
            "@trigora/sdk": ["../../packages/sdk/src"],
            "@trigora/shared": ["../../packages/contracts/src"],
            "@trigora/cli": ["../../packages/cli/src"]
        },

        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "ESNext",
        "moduleResolution": "Bundler",

        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,

        "resolveJsonModule": true,
        "isolatedModules": true,

        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true,

        "forceConsistentCasingInFileNames": true
    }
}